# Dyno Dashboard Environment Variables

# Supabase Configuration
REACT_APP_SUPABASE_URL=your_supabase_project_url
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Supabase Service Role Key (for admin functions)
# SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Optional: Custom API endpoints
# REACT_APP_DYNO_AI_ENDPOINT=https://your-dyno-ai-api.com
# REACT_APP_DYNO_AI_API_KEY=your_dyno_ai_api_key

# Optional: Analytics and monitoring
# REACT_APP_ANALYTICS_ID=your_analytics_id
# REACT_APP_SENTRY_DSN=your_sentry_dsn

# Development settings
# REACT_APP_DEBUG=true
# REACT_APP_MOCK_DATA=true
